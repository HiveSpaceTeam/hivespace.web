{
  "name": "hivespace-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":            "turbo run dev",
    "dev:admin":      "turbo run dev --filter=@hivespace/admin",
    "dev:seller":     "turbo run dev --filter=@hivespace/seller",
    "dev:buyer":      "turbo run dev --filter=@hivespace/buyer",
    "build":          "turbo run build",
    "build:shared":   "turbo run build --filter=@hivespace/shared",
    "test":           "turbo run test",
    "quality-gate":   "node scripts/quality-gate.mjs",
    "type-check":     "turbo run type-check",
    "lint":           "turbo run lint",
    "format":         "turbo run format"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "~5.7.3",
    "prettier": "^3.6.2",
    "eslint": "^9.18.0",
    "jiti": "^2.4.2",
    "@hivespace/eslint-config": "workspace:*",
    "@jest/globals": "^29.7.0",
    "@pinia/testing": "^1.0.0",
    "@vue/vue3-jest": "^29.2.6",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "vue-i18n": "^9.3.0"
    }
  }
}
