{
  "extends": "@hivespace/tsconfig/vue-app",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "isolatedModules": true,

    "paths": {
      "@/*": ["./src/*"],
      "@hivespace/demo": ["../../packages/demo/src/index.d.ts"],
      "@hivespace/shared": ["../../packages/shared/src/index.ts"],
      "@hivespace/shared/test-utils": ["../../packages/shared/src/test-utils/index.ts"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
